{
  "name": "@bitfit/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "tsup",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@storybook/react-vite": "^8.6.14",
    "@tailwindcss/cli": "^4",
    "@tailwindcss/vite": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^8.6.14",
    "tailwindcss": "^4",
    "tsup": "^8.3.5",
    "typescript": "^5",
    "vite": "^6"
  }
}
