# --- Anthropic (Claude) ---
# API key for the Claude LLM. Swappable without code changes.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Model name to use. Swap freely (config change, not code change).
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Google Health API (OAuth2, backend-only) ---
GOOGLE_HEALTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_HEALTH_CLIENT_SECRET=your-client-secret
# Must match a redirect URI registered in your Google Cloud OAuth client.
GOOGLE_HEALTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Encryption ---
# Fernet key used to encrypt the stored OAuth refresh token at rest.
# Generate one with:
#   python scripts/generate_key.py
TOKEN_ENCRYPTION_KEY=replace-with-generated-fernet-key

# --- Database ---
# SQLModel/SQLAlchemy connection URL. Defaults to a local SQLite file.
DATABASE_URL=sqlite:///./health.db

# --- Background sync ---
# How often (in hours) the scheduler pulls fresh data from the Google Health
# API. Defaults to 4. The first run is deferred a few minutes after startup so
# booting the server never blocks on a network sync.
SYNC_INTERVAL_HOURS=4

# --- App login ---
# This is a personal single-user app with no accounts system — APP_PASSWORD is
# the one password that gates the whole app so it isn't wide open on the
# network. SESSION_SECRET signs the login cookie; generate both with:
#   python scripts/generate_key.py   (for SESSION_SECRET; any random string
#                                      works, this is just a convenient source)
APP_PASSWORD=choose-a-password
SESSION_SECRET=replace-with-a-generated-random-secret
